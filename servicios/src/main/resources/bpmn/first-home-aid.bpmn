<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="first-home-aid"
                  targetNamespace="http://magenta.com/bpmn"
                  exporter="Camunda Modeler" exporterVersion="5.0">

  <bpmn:process id="first-home-aid" name="First Home Aid" isExecutable="true">

    <bpmn:startEvent id="start" name="Orden aceptada">
      <bpmn:outgoing>flow1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="validateInputs" name="Validar inputs">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="validateInputs"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow1</bpmn:incoming>
      <bpmn:outgoing>flow2</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="quotePrice" name="Calcular precio">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="quotePrice"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow2</bpmn:incoming>
      <bpmn:outgoing>flow3</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="chargeCustomer" name="Cobrar cliente">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="chargeCustomer"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow3</bpmn:incoming>
      <bpmn:outgoing>flow4</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="requestPreapproval" name="Solicitar preaprobación banco">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="requestPreapproval"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow4</bpmn:incoming>
      <bpmn:outgoing>flow5</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:intermediateCatchEvent id="waitPreapproval" name="Esperar respuesta banco">
      <bpmn:incoming>flow5</bpmn:incoming>
      <bpmn:outgoing>flow6</bpmn:outgoing>
      <bpmn:messageEventDefinition messageRef="preapprovalReceived"/>
    </bpmn:intermediateCatchEvent>

    <bpmn:exclusiveGateway id="check905" name="¿Califica 90+5+5?">
      <bpmn:incoming>flow6</bpmn:incoming>
      <bpmn:outgoing>flow7yes</bpmn:outgoing>
      <bpmn:outgoing>flow7no</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="assignPartner" name="Asignar partner">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="assignPartner"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow7yes</bpmn:incoming>
      <bpmn:outgoing>flow8</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:userTask id="clientReviewOffer" name="Cliente revisa oferta">
      <bpmn:incoming>flow8</bpmn:incoming>
      <bpmn:outgoing>flow9</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="notifySuccess" name="Notificar cliente">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="notifyCustomer"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow9</bpmn:incoming>
      <bpmn:incoming>flow7no</bpmn:incoming>
      <bpmn:outgoing>flow10</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="closeOrder" name="Cerrar orden">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="closeOrder"/>
      </bpmn:extensionElements>
      <bpmn:incoming>flow10</bpmn:incoming>
      <bpmn:outgoing>flow11</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="end" name="Completado">
      <bpmn:incoming>flow11</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence flows -->
    <bpmn:sequenceFlow id="flow1"  sourceRef="start"             targetRef="validateInputs"/>
    <bpmn:sequenceFlow id="flow2"  sourceRef="validateInputs"    targetRef="quotePrice"/>
    <bpmn:sequenceFlow id="flow3"  sourceRef="quotePrice"        targetRef="chargeCustomer"/>
    <bpmn:sequenceFlow id="flow4"  sourceRef="chargeCustomer"    targetRef="requestPreapproval"/>
    <bpmn:sequenceFlow id="flow5"  sourceRef="requestPreapproval" targetRef="waitPreapproval"/>
    <bpmn:sequenceFlow id="flow6"  sourceRef="waitPreapproval"   targetRef="check905"/>
    <bpmn:sequenceFlow id="flow7yes" sourceRef="check905" targetRef="assignPartner">
      <bpmn:conditionExpression>=qualifiesFor905</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow7no" sourceRef="check905" targetRef="notifySuccess">
      <bpmn:conditionExpression>=not(qualifiesFor905)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="flow8"  sourceRef="assignPartner"     targetRef="clientReviewOffer"/>
    <bpmn:sequenceFlow id="flow9"  sourceRef="clientReviewOffer" targetRef="notifySuccess"/>
    <bpmn:sequenceFlow id="flow10" sourceRef="notifySuccess"     targetRef="closeOrder"/>
    <bpmn:sequenceFlow id="flow11" sourceRef="closeOrder"        targetRef="end"/>
  </bpmn:process>

  <bpmn:message id="preapprovalReceived" name="preapprovalReceived"/>

</bpmn:definitions>
