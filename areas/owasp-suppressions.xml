<?xml version="1.0" encoding="UTF-8"?>
<!--
  Supresiones de falsos positivos para OWASP Dependency-Check.

  Proceso:
  1. Ejecutar mvn verify (o dependency-check:check) y revisar el reporte HTML en
     target/dependency-check-report/dependency-check-report.html
  2. Para cada falso positivo, añadir una entrada <suppress> con:
     - <notes>: justificación y fecha de revisión
     - <cve>: el CVE exacto a suprimir
     - <filePath regex="true">: ruta del artefacto afectado (patrón regex)

  IMPORTANTE: cada supresión debe tener fecha de revisión y ser re-evaluada
  trimestralmente. Nunca suprimir CVEs de CVSS >= 9 sin aprobación explícita
  del responsable de seguridad.
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!--
    Ejemplo (eliminar antes de productizar):
    <suppress>
        <notes><![CDATA[
          Revisado 2026-06-01 por [nombre].
          CVE-XXXX-YYYY afecta solo al modo X que no usamos porque Y.
          Re-evaluar en 2026-09-01.
        ]]></notes>
        <cve>CVE-XXXX-YYYY</cve>
        <filePath regex="true">.*biblioteca-afectada-.*\.jar</filePath>
    </suppress>
    -->

</suppressions>
